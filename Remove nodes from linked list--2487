ListNode* removeNodes(ListNode* head) {
        ListNode* curr=head;
        ListNode* prev=NULL;
        while(curr!=NULL){
            ListNode* next=curr->next;
            curr->next=prev;
            prev=curr;
            curr=next;
        }
        ListNode* temp=prev;
        int maxval=temp->val;
        while(temp!=NULL && temp->next!=NULL){
            if(temp->next->val < maxval){
                temp->next=temp->next->next;
            }
            else{
                temp=temp->next;
                maxval=temp->val;
            }
        }
        curr=prev;
        prev=NULL;
        while(curr!=NULL){
            ListNode* next=curr->next;
            curr->next=prev;
            prev=curr;
            curr=next;
        }
        return prev;  
    }
