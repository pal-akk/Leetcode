vector<int> sortEvenOdd(vector<int>& nums) {
        int n= nums.size();
        for(int i=0;i<n;i+=2){
            int min=i;
            for(int j=i+2;j<n;j+=2){
                if(nums[j]<nums[min]) min=j;
            }
            swap(nums[i],nums[min]);
        }
        for(int i=1;i<n;i+=2){
            int max=i;
            for(int j=i+2;j<n;j+=2){
                if(nums[j]>nums[max]) max=j;
            }
            swap(nums[i],nums[max]);
        }
        return nums;
    }
