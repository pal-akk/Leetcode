int n = word.size();
        int num=1;
        for(int i=0 ; i<n ;){
            int j=i;
            while(j<n && word[i]==word[j]){
                ++j;
            }
            int gruplen= j-i;
            if(gruplen>1){
                num+=gruplen-1;
            }
            i=j;
        }
        return num;  
    }
