vector<int> sortedSquares(vector<int>& nums) {
        int n= nums.size();
        vector<int> res(n);
        int left =0;
        int right=n-1;
        int ind=n-1;
        while(left<=right){
            if(abs(nums[left])>abs(nums[right])){
                res[ind--]=nums[left]*nums[left];
                left++;
            }
            else{
                res[ind--]=nums[right]*nums[right];
                right--;
            }
        }
        return res;
    }
