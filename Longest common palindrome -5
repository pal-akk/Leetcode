string longestPalindrome(string s) {
        int n= s.size();
        if(n==0) return "";
        int start= 0;
        int maxlen=1;
        for(int center=0; center<n ;center++){
            int l= center;
            int r=center;
            while(l>=0 && r<n && s[l]==s[r]){
                if(r-l+1 >maxlen){
                    start=l;
                    maxlen=r-l+1;
                }
                l--;
                r++;
            }
            l= center;
            r=center+1;
            while(l>=0 && r<n && s[l]==s[r]){
                if(r-l+1 >maxlen){
                    start=l;
                    maxlen=r-l+1;
                }
                l--;
                r++;
            }

        }
        return s.substr(start , maxlen);
        
    }
