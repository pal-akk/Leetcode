int numIdenticalPairs(vector<int>& nums) {
        int n= nums.size();
        int cnt=0;
        unordered_map<int,int> freq;
        for(int num  : nums){
            cnt+=freq[num]; // when no. occurs one time its 0 in hash then gets ++ then on second time its value added to cnt nd then in hash is++ after it occurs no more so cnt is 1 considering pair
            freq[num]++;
        }
        return cnt;
        
    }
