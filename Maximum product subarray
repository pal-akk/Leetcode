int maxProduct(vector<int>& nums) {
        int n= nums.size();
        int high=nums[0];
        int mini=nums[0];
        int maxi= nums[0];
        for(int i=1 ;i<n ;i++){
            int temp =maxi;
            maxi=max({nums[i], nums[i]* maxi ,nums[i]*mini});
            mini =min({nums[i], nums[i]* temp ,nums[i]*mini});
            high=max(high ,maxi);
        }
        return high;
    }
