string removeOuterParentheses(string s) {
        string result;
        int n=s.length();
        vector<int> count;
        int depth=0;
        for(char ch :s){
            if(ch=='('){
                if(depth >0) result +='(';
                depth ++;
            }
            else{
                depth--;
                if(depth > 0) result+= ')';
            }
        }
        return result; 
    }
