int pivotIndex(vector<int>& nums) {
        int n=nums.size();
        int s1=0;
        int sum=0;
        for(int i=0;i<n;i++){
            sum+=nums[i];
        }
        for(int i=0;i<n;i++){
            int s2=sum-nums[i]-s1;
            if(s1==s2) return i;
            s1+=nums[i];
        }
        return -1;
        
    }
