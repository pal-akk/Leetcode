bool isSameAfterReversals(int num) {
        int r1=reversenum(num);
        int r2=reversenum(r1);
        if(r2==num) return true;
        else return false;
    }
    int reversenum(int n){
        int res=0;
        int d=n;
        while(d){
            res=res*10+d%10;
            d=d/10;
        }
        return res;
    }
